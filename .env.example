# Earl Dashboard Environment Variables
# Copy this to .env.local and fill in values

# ---- Required ----

# SQLite database file path (relative to project root)
DATABASE_URL=file:./data/earl.db

# ---- Optional: Earl AI API ----

# API key for the Earl AI integration endpoint (/api/earl)
# Default dev key is used if not set
EARL_API_KEY=earl-dev-key-change-me

# ---- Optional: External Services ----

# Resend API key for email notifications
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe API key (for future monetization)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# PostHog analytics (self-hosted or cloud)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Vercel KV (for rate limiting / caching in production)
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# ---- Optional: Supabase (future multi-device sync) ----

# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
